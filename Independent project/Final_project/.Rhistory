theme(legend.position = "right")
view(HNLChlorophyll_sites)
view(HNLChlorophyll_sites_list)
names(HNLChlorophyll_sites_list)
names(byECO3_HNLChlorophyll_sites)
names(byECO9_HNLChlorophyll_sites)
#Overlap between sites ----
df1 <- HNLChlorophyll_sites_list %>%
mutate(source = "HNL")
df2 <- byECO3_HNLChlorophyll_sites %>%
mutate(source = "ECO3")
df3 <- byECO9_HNLChlorophyll_sites %>%
mutate(source = "ECO9")
all_sites <- bind_rows(df1, df2, df3)
site_overlap <- all_sites %>%
group_by(SITE_ID) %>%
summarise(
sources = paste(unique(source), collapse = ", "),
n_sources = n_distinct(source),
overlap_type = case_when(
n_sources == 3 ~ "All three",
n_sources == 2 ~ "Two datasets",
n_sources == 1 ~ "Unique",
TRUE ~ "Other"
),
.groups = "drop"
)
final_data <- all_sites %>%
left_join(site_overlap, by = "SITE_ID")
View(final_data)
site_overlap %>% count(overlap_type)
site_overlap <- all_sites %>%
group_by(SITE_ID) %>%
summarise(
sources = paste(sort(unique(source)), collapse = " + "),
n_sources = n_distinct(source),
.groups = "drop"
)
site_overlap
view(site_overlap)
final_unique <- final_data %>%
group_by(SITE_ID) %>%
summarise(
LAT_DD83 = first(LAT_DD83),
LON_DD83 = first(LON_DD83),
PTL_RESULT = mean(PTL_RESULT, na.rm = TRUE),
NTL_RESULT = mean(NTL_RESULT, na.rm = TRUE),
CHLA_RESULT = mean(CHLA_RESULT, na.rm = TRUE),
nutrient_group = first(nutrient_group),
sources = first(sources),
n_sources = first(n_sources),
overlap_type = first(overlap_type),
.groups = "drop"
)
view(final_unique)
#mapping by overlap
ggplot(final_unique, aes(x = LON_DD83, y = LAT_DD83)) +
geom_point(aes(color = nutrient_group, shape = factor(n_sources)), size = 3) +
labs(
title = "Site Overlap and Nutrient Groups",
color = "Nutrient Group",
shape = "Overlap (datasets)"
) +
theme_minimal()
