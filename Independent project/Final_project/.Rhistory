ggplot(final_unique, aes(x = LON_DD83, y = LAT_DD83)) +
borders("state", color = "gray70", fill = "gray95") +
geom_point(aes(color = nutrient_group, shape = overlap_label), size = 3) +
coord_fixed(1.3) +
theme_minimal()
