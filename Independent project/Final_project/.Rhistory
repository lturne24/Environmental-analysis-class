map_data_lowCHL <- full_data %>%
filter(!is.na(nutrient_group_lowCHL)) %>%
left_join(
SiteInfo %>% select(SITE_ID, LAT_DD83, LON_DD83),
by = "SITE_ID"
) %>%
distinct(SITE_ID, LAT_DD83, LON_DD83, nutrient_group_lowCHL)
