geom_point(data = combined_spatial,
aes(x = LON_DD83, y = LAT_DD83),
color = "grey80",
size = 1) +
geom_point(data = subset(combined_spatial, HNLC_strict == 1),
aes(x = LON_DD83, y = LAT_DD83),
color = "blue",
size = 2) +
coord_fixed(1.3) +
theme_minimal() +
labs(title = "High N + High P – Low Chlorophyll Sites",
