geom_polygon(
data = us_states,
aes(x = long, y = lat, group = group),
fill = "gray95",
color = "black"
) +
# Add site points
geom_point(
data = map_data_lowCHL,
aes(x = LON_DD83, y = LAT_DD83, color = nutrient_group_lowCHL),
size = 3,
alpha = 0.7
) +
# Colors
scale_color_manual(
