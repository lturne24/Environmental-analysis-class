library(sf)
library(leaflet)
library(dplyr)
library(readr)

# Read data
counties <- sf::read_sf("./CBW/County_Boundaries.shp") %>% sf::st_make_valid()
stations <- sf::read_sf("./CBW/Non-Tidal_Water_Quality_Monitoring_Stations_in_the_Chesapeake_Bay.shp")
dams <- sf::read_sf("./CBW/Dam_or_Other_Blockage_Removed_2012_2017.shp") %>% sf::st_make_valid()

# Color palette for dam removal year
dam_pal <- colorNumeric(
  palette = "YlOrRd",
  domain = dams$DamRemoval
)

# Custom icon for dams
dam_icon <- makeAwesomeIcon(
  icon = "industry",        # you can try "tint", "warning", "cog"
  markerColor = "red",
  iconColor = "white",
  library = "fa"
)

G2 <- leaflet() %>%
  setView(lng = -77.3, lat = 38.6, zoom = 7) %>%
  
  # ---- BASE MAPS ----
addProviderTiles(providers$Esri.NatGeoWorldMap, group = "NatGeo") %>%
  addProviderTiles(providers$CartoDB.Positron, group = "Light") %>%
  addProviderTiles(providers$Esri.WorldImagery, group = "Satellite") %>%
  
  # ---- COUNTIES ----
addPolygons(
  data = counties,
  color = "black",
  weight = 1,
  fill = FALSE,
  group = "Counties"
) %>%
  
  # ---- MONITORING STATIONS ----
addCircleMarkers(
  data = stations,
  radius = ~sqrt(Drainage_A) / 10,
  fillColor = "blue",
  fillOpacity = 0.5,
  color = "blue",
  stroke = TRUE,
  weight = 1,
  group = "Monitoring Stations",
  popup = ~paste("Drainage Area:", Drainage_A)
) %>%
  
  # ---- DAMS (CUSTOM ICON + COLOR BY YEAR) ----
addAwesomeMarkers(
  data = dams,
  icon = dam_icon,
  markerColor = ~dam_pal(DamRemoval),
  group = "Dam Removals",
  popup = ~paste("Year Removed:", DamRemoval)
) %>%
  
  # ---- LEGEND FOR DAM YEARS ----
addLegend(
  "bottomright",
  pal = dam_pal,
  values = dams$DamRemoval,
  title = "Dam Removal Year"
) %>%
  
  # ---- LAYER CONTROL ----
addLayersControl(
  baseGroups = c("NatGeo", "Light", "Satellite"),
  overlayGroups = c("Counties", "Monitoring Stations", "Dam Removals"),
  options = layersControlOptions(collapsed = FALSE)
)

