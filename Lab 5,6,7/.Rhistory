overlayGroups = c("Counties", "Monitoring Stations", "Dam Removals"),
options = layersControlOptions(collapsed = FALSE))
G2
library(sf)
library(leaflet)
library(dplyr)
library(readr)
# Read data
counties <- sf::read_sf("./CBW/County_Boundaries.shp") %>% sf::st_make_valid()
stations <- sf::read_sf("./CBW/Non-Tidal_Water_Quality_Monitoring_Stations_in_the_Chesapeake_Bay.shp")
dams <- sf::read_sf("./CBW/Dam_or_Other_Blockage_Removed_2012_2017.shp") %>% sf::st_make_valid()
G2 <- leaflet() %>%
setView(lng = -77.3, lat = 38.6, zoom = 7) %>%
addProviderTiles(providers$Esri.NatGeoWorldMap, group = "NatGeo") %>%
addProviderTiles(providers$CartoDB.Positron, group = "Light") %>%
addProviderTiles(providers$Esri.WorldImagery, group = "Satellite") %>%
addProviderTiles(providers$Stadia.StamenToner, group = "BW") %>%
addProviderTiles(providers$CartoDB.DarkMatter, group = "Goth") %>%
addPolygons(
data = counties,
color = "black",
weight = 1,
fill = FALSE,
group = "Counties")%>%
##adds drainage area
addCircleMarkers(
data = stations,
radius = ~sqrt(Drainage_A) / 10,
fillColor = "blue",
fillOpacity = 0.5,
color = "blue",
stroke = TRUE,
weight = 1,
group = "Monitoring Stations",
popup = ~paste("Drainage Area:", Drainage_A)) %>%
#year dams removed
addCircleMarkers(
data = dams,
radius = 5,
fillColor = ~colorNumeric(
palette = "YlOrRd",
domain = dams$DamRemoval
)(DamRemoval),
fillOpacity = 0.8,
color = "black",
weight = 1,
group = "Dam Removals",
popup = ~paste("Year Removed:", DamRemoval)) %>%
#make so flip between layers
addLayersControl(
baseGroups =c("NatGeo", "Light", "Satellite", "BW", "Goth"),
overlayGroups = c("Counties", "Monitoring Stations", "Dam Removals"),
options = layersControlOptions(collapsed = FALSE))
G2
View(dams)
View(dams)
damAwesomeIcon <- makeAwesomeIcon(
icon = "water",
library = "fa",
markerColor = "blue",
iconColor = "white"
)
View(damAwesomeIcon)
