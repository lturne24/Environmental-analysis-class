theme_minimal()
# your code here
# pick two rasters
r_early <- r_stack[[1]]
r_late <- r_stack[[2]]
# binary
b1 <- !is.na(r_early)
b2 <- !is.na(r_late)
# convert to numeric
b1 <- as.numeric(b1)
b2 <- as.numeric(b2)
# persistent
persistent <- b1 * b2
# new bloom
new_bloom <- (b2 == 1) & (b1 == 0)
# maps
tm_shape(persistent) + tm_raster(title = "Persistent Bloom")
tm_shape(new_bloom) + tm_raster(title = "New Bloom")
# your code here
r_early <- r_stack[[1]]
r_late  <- r_stack[[2]]
# binary rasters
b1 <- ifel(!is.na(r_early), 1, 0)
b2 <- ifel(!is.na(r_late), 1, 0)
# persistent bloom
persistent <- b1 * b2
# new bloom
new_bloom <- ifel(b2 == 1 & b1 == 0, 1, 0)
# maps
tm_shape(persistent) + tm_raster(title = "Persistent Bloom")
tm_shape(new_bloom) + tm_raster(title = "New Bloom")
# choose two dates (first = earlier, second = later)
r_early <- r_stack[[1]]
r_late  <- r_stack[[2]]
# binary rasters: 1 = bloom present, 0 = no bloom
b_early <- terra::ifel(!is.na(r_early), 1, 0)
b_late  <- terra::ifel(!is.na(r_late), 1, 0)
# persistent bloom (present in both)
persistent_bloom <- b_early * b_late
# new bloom (present later, not earlier)
new_bloom <- terra::ifel(b_late == 1 & b_early == 0, 1, 0)
# map persistent
tm_shape(persistent_bloom) +
tm_raster(title = "Persistent Bloom") +
tm_layout(title = "Persistent Cyanobacteria Bloom")
# map new bloom
tm_shape(new_bloom) +
tm_raster(title = "New Bloom") +
tm_layout(title = "New Cyanobacteria Bloom")
