terra::crs(aois_vect)
terra::crs(best_raster)
# Properly project AOIs to raster CRS
aois_vect <- terra::project(aois_vect, best_raster)
# Now crop + mask
raster_crop <- terra::crop(best_raster, aois_vect)
raster_mask <- terra::mask(raster_crop, aois_vect)
# Plot
tm_shape(raster_mask) +
tm_raster(
palette = "YlGnBu",
title = "Cyanobacteria Index"
) +
tm_shape(aois_vect) +
tm_borders(col = "red", lwd = 2) +
tm_layout(
title = "Cyanobacteria Bloom Intensity (Sept 20–26, 2017)",
legend.outside = TRUE
) +
tm_scalebar()
library(terra)
library(sf)
library(tidyverse)
library(tmap)
library(fs)
# your code here
raster_files <- fs::dir_ls("erie_raster_ex/images/", regexp = "\\.tif$")
raster_files
length(raster_files)
# your code here
# load first raster
r1 <- terra::rast(raster_files[1])
# Coords
terra::crs(r1)
# extent
terra::ext(r1)
# resolution
terra::res(r1)
# layers
terra::nlyr(r1)
# min and max
terra::global(r1, c("min", "max"), na.rm = TRUE)
# your code here
clean_cicyano <- function(r) {
rcl <- matrix(c(
0, 0, NA,
249, 255, NA
), ncol = 3, byrow = TRUE)
r_clean <- terra::classify(r, rcl)
return(r_clean)}
# plz work
r1_clean <- clean_cicyano(r1)
terra::global(r1, c("min", "max"), na.rm = TRUE)
terra::global(r1_clean, c("min", "max"), na.rm = TRUE)
# your code here
dn_to_ci <- function(r) {
ci <- 10^((3.0 / 250.0) * r - 4.2)
return(ci)}
#plzzzzz work
r1_ci <- dn_to_ci(r1_clean)
terra::global(r1_ci, c("min", "max"), na.rm = TRUE)
# your code here
aoi <- sf::read_sf("erie_raster_ex/bounds/bb_erie_sandusky.shp")
# check Coords
st_crs(aoi)
terra::crs(r1)
aoi <- st_transform(aoi, crs = terra::crs(r1))
# your code here
target_file <- raster_files[grepl("0816_0822", raster_files)]
r_target <- rast(target_file)
r_target_clean <- clean_cicyano(r_target)
r_target_ci <- dn_to_ci(r_target_clean)
# convert sf to vect
aoi_vect <- terra::vect(aoi)
r_crop <- terra::crop(r_target_ci, aoi_vect)
sandusky_0816 <- terra::mask(r_crop, aoi_vect)
# your code here
#full erie mean
terra::global(r_target_ci, "mean", na.rm = TRUE)
# just sandusky mean
terra::global(sandusky_0816, "mean", na.rm = TRUE)
# your code here
tmap_mode("plot")
tm_shape(sandusky_0816) +
tm_raster(title = "Cyanobacteria Index") +
tm_layout(title = "CI in Sandusky Bay (Aug 16–22, 2017)") +
tm_scale_bar()
# your code here
# choose 4 rasters
selected_files <- raster_files[1:4]
r_stack <- selected_files %>%
purrr::map(~ rast(.x) %>%
clean_cicyano() %>%
dn_to_ci()) %>% reduce(c)
# your code here
means <- terra::global(r_stack, "mean", na.rm = TRUE)
dates <- basename(selected_files) %>%
stringr::str_extract("\\d{4}_\\d{4}")
df_time <- data.frame(
date = dates,
mean_ci = means[,1])
df_time
# your code here
ggplot(df_time, aes(x = date, y = mean_ci, group = 1)) +
geom_line() +
geom_point() +
labs(x = "Date", y = "Mean CI", title = "Bloom Intensity Over Time") +
theme_minimal()
best_file <- raster_files[grepl("0920_0926", raster_files)]
best_raster <- rast(best_file) %>%
clean_cicyano() %>%
dn_to_ci()
# choose two dates (first = earlier, second = later)
r_early <- r_stack[[2]]
r_late  <- r_stack[[4]]
r_early_na0 <- terra::ifel(is.na(r_early), 0, r_early)
r_late_na0  <- terra::ifel(is.na(r_late), 0, r_late)
rcl <- matrix(c(
0, 0, 0,
0.00001, Inf, 1
), ncol = 3, byrow = TRUE)
b_early <- terra::classify(r_early_na0, rcl)
b_late  <- terra::classify(r_late_na0, rcl)
persistent_bloom <- b_early * b_late
new_bloom <- terra::ifel(b_late == 1 & b_early == 0, 1, 0)
plot(persistent_bloom,
col = c("lightgrey", "red"),
main = "Persistent Bloom")
plot(new_bloom,
col = c("lightgrey", "blue"),
main = "New Bloom")
# your code here
shp_files <- list.files("./erie_raster_ex/bounds/",
pattern = "\\.shp$", full.names = TRUE)
aois <- shp_files %>%
purrr::map(~ {
x <- sf::read_sf(.x)
x <- sf::st_make_valid(x)
x <- dplyr::mutate(x, aoi_name = basename(.x))
return(x)
}) %>%
dplyr::bind_rows()
# convert to terra
aois_vect <- terra::vect(aois)
# check
aois
aois_vect
# your code here
vals <- terra::extract(best_raster, aois_vect)
vals$aoi_name <- aois$aoi_name[vals$ID]
summary_stats <- vals %>%
dplyr::group_by(aoi_name) %>%
dplyr::summarize(
mean_ci = mean(.[[2]], na.rm = TRUE),
max_ci  = max(.[[2]], na.rm = TRUE))
# your code here
summary_stats
