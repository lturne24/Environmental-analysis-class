purrr::map(~ {
x <- sf::read_sf(.x)
# fix geometry BEFORE combining
x <- sf::st_make_valid(x)
# add name
x <- dplyr::mutate(x, aoi_name = basename(.x))
return(x)
}) %>%
dplyr::bind_rows()
